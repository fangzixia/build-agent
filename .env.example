WORKSPACE_ROOT=E:/AI/projects
CMD_TIMEOUT_SEC=90
HTTP_ADDR=:8080

# 项目分析
ANALYSIS_OPENAI_BASE_URL=https://api.openai.com/v1
ANALYSIS_OPENAI_API_KEY=your_analysis_key
ANALYSIS_OPENAI_MODEL=gpt-4o-mini
ANALYSIS_EXECUTOR_MAX_ITERATIONS=100
ANALYSIS_PLAN_EXECUTE_MAX_ITERATIONS=100

# 需求分析
REQUIREMENTS_OPENAI_BASE_URL=https://api.openai.com/v1
REQUIREMENTS_OPENAI_API_KEY=your_requirements_key
REQUIREMENTS_OPENAI_MODEL=gpt-4o-mini
REQUIREMENTS_EXECUTOR_MAX_ITERATIONS=100
REQUIREMENTS_PLAN_EXECUTE_MAX_ITERATIONS=100

# 编码执行
CODE_OPENAI_BASE_URL=https://api.openai.com/v1
CODE_OPENAI_API_KEY=your_code_key
CODE_OPENAI_MODEL=gpt-4o-mini
CODE_EXECUTOR_MAX_ITERATIONS=100
CODE_PLAN_EXECUTE_MAX_ITERATIONS=100

# 验收评测
EVAL_OPENAI_BASE_URL=https://api.openai.com/v1
EVAL_OPENAI_API_KEY=your_eval_key
EVAL_OPENAI_MODEL=gpt-4o-mini
EVAL_EXECUTOR_MAX_ITERATIONS=100
EVAL_PLAN_EXECUTE_MAX_ITERATIONS=100

# 完整构建
BUILD_OPENAI_BASE_URL=https://api.openai.com/v1
BUILD_OPENAI_API_KEY=your_build_key
BUILD_OPENAI_MODEL=gpt-4o-mini
BUILD_EXECUTOR_MAX_ITERATIONS=20
BUILD_PLAN_EXECUTE_MAX_ITERATIONS=10
BUILD_MAX_RETRIES=5
